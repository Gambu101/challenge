# Solana RPC endpoint (use SolInfra / Triton for production)
RPC_ENDPOINT=https://api.devnet.solana.com

# Jito block engine endpoint
# Devnet: https://bundles.jito.wtf
# Mainnet: https://mainnet.block-engine.jito.wtf
JITO_ENDPOINT=https://bundles.jito.wtf

# Yellowstone gRPC endpoint (Triton / SolInfra)
# Format: https://your-endpoint.rpcpool.com
GEYSER_ENDPOINT=
GEYSER_TOKEN=

# Your wallet private key (base58 encoded)
# Leave empty to use a generated demo keypair (no real transactions)
WALLET_PRIVATE_KEY=

# Anthropic API key for the AI agent
ANTHROPIC_API_KEY=your_anthropic_api_key_here
